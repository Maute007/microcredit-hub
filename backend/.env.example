# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=euro-server.makira7.com,localhost,127.0.0.1

# Frontend (CORS, CSRF)
FRONTEND_URL=https://euro-credito.makira7.com
BACKEND_URL=https://euro-server.makira7.com
# Se precisar permitir mais origens (ex: staging), separe por vírgulas:
# CORS_ALLOWED_ORIGINS_EXTRA=https://staging-euro-credito.makira7.com

# JWT
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Database (opcional - SQLite por defeito)
# Opção 1 (recomendado): URL única
# DATABASE_URL=postgres://user:password@db-host:5432/dbname
#
# Opção 2: variáveis separadas (sem DATABASE_URL)
# POSTGRES_DB=microcredit
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=secret
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_SSLMODE=prefer
