# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend (CORS, CSRF)
FRONTEND_URL=http://localhost:5173

# JWT
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Database (opcional - SQLite por defeito)
# Para PostgreSQL: DATABASE_URL=postgres://user:password@localhost:5432/dbname
# Requer psycopg2-binary instalado
